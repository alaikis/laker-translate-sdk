{
  "name": "@alaikis/translation-sdk",
  "version": "1.5.3",
  "description": "Translation Service Connect RPC JavaScript/TypeScript SDK",
  "type": "module",
  "main": "translation-client.cjs",
  "module": "translation-client.js",
  "types": "translation-client.d.ts",
  "files": [
    "*.js",
    "*.d.ts",
    "gen/*.js",
    "gen/*.d.ts",
    "google/**/*.js",
    "google/**/*.d.ts"
  ],
  "scripts": {
    "build": "npx rollup --config rollup.config.js"
  },
  "keywords": [
    "translation",
    "connect-rpc",
    "grpc",
    "streaming",
    "laker",
    "llm"
  ],
  "author": "alaikis",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alaikis/laker-translate-sdk.git",
    "directory": "js"
  },
  "bugs": {
    "url": "https://github.com/alaikis/laker-translate-sdk/issues"
  },
  "homepage": "https://github.com/alaikis/laker-translate-sdk#readme",
  "devDependencies": {
    "@bufbuild/protoc-gen-es": "^2.11.0",
    "@connectrpc/protoc-gen-connect-es": "^1.7.0",
    "@rollup/plugin-typescript": "^12.1.1",
    "abort-controller": "^3.0.0",
    "eventsource": "^2.0.2",
    "node-fetch": "^2.7.0",
    "rollup": "^4.34.8",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-web": "^2.1.1",
    "broadcast-channel": "^7.3.0"
  }
}
