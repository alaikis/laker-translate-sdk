{
  "name": "@alaikis/translation-sdk",
  "version": "1.6.125",
  "description": "Translation Service Connect RPC JavaScript/TypeScript SDK",
  "type": "module",
  "main": "translation-client.cjs",
  "module": "translation-client.js",
  "browser": "translation-client.js",
  "types": "translation-client.d.ts",
  "exports": {
    ".": {
      "require": "./translation-client.cjs",
      "import": "./translation-client.js",
      "browser": "./translation-client.js",
      "default": "./translation-client.js"
    }
  },
  "files": [
    "*.js",
    "*.js.map",
    "*.cjs",
    "*.cjs.map",
    "*.d.ts",
    "gen/*.js",
    "gen/*.js.map",
    "gen/*.d.ts",
    "gen/**/*.js",
    "gen/**/*.js.map",
    "gen/**/*.d.ts"
  ],
  "scripts": {
    "build": "npx rollup --config rollup.config.js"
  },
  "keywords": [
    "translation",
    "connect-rpc",
    "grpc",
    "streaming",
    "laker",
    "llm"
  ],
  "author": "alaikis",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alaikis/laker-translate-sdk.git",
    "directory": "js"
  },
  "bugs": {
    "url": "https://github.com/alaikis/laker-translate-sdk/issues"
  },
  "homepage": "https://github.com/alaikis/laker-translate-sdk#readme",
  "devDependencies": {
    "@bufbuild/protobuf": "^1.10.0",
    "@bufbuild/protoc-gen-es": "^1.10.0",
    "@connectrpc/protoc-gen-connect-es": "^1.7.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-inject": "^5.0.5",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-typescript": "^12.1.1",
    "@types/node": "^25.6.0",
    "abort-controller": "^3.0.0",
    "eventsource": "^2.0.2",
    "node-fetch": "^2.7.0",
    "rollup": "^4.34.8",
    "rollup-plugin-node-polyfills": "^0.2.1",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^1.10.0",
    "@connectrpc/connect": "^1.7.0",
    "@connectrpc/connect-node": "^1.7.0",
    "@connectrpc/connect-web": "^1.7.0",
    "broadcast-channel": "^7.3.0"
  }
}
